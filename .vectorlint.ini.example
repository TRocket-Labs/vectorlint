# VectorLint Configuration Example
# Global settings

# Optional: Path to custom rules directory
# If omitted, only preset rules (from RunRules) are used
# RulesPath=path-to-rules

Concurrency=4
DefaultSeverity=warning

# Default rules for all markdown files
[**/*.md]
RunRules=Acme

# Blog content
[content/blog/**/*.md]
RunRules=Acme

# Technical documentation
[content/docs/**/*.md]
RunRules=Acme

# Marketing content - use custom pack
[content/marketing/**/*.md]
RunRules=Acme

# Skip drafts entirely
[content/drafts/**/*.md]
RunRules=